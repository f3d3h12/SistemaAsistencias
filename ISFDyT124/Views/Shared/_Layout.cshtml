<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Sistema de Asistencias</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body class="@ViewData["BodyClass"]">

    <header class="top-header">
        <div class="menu-icon">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>

        <div class="header-title">
            <div class="title-small">SISTEMA</div>
            <div class="title-large">ASISTENCIAS</div>
        </div>

        <div class="header-logo">
            <img src="~/images/logo.png" alt="IS 124" class="logo-img">
        </div>
    </header>

    <nav class="sidebar" id="sidebarMenu">
        <ul class="sidebar-links">
            <li>
                <span class="menu-arrow">➔</span>
                <a asp-controller="Home" asp-action="Index">Inicio</a>
            </li>
            <li>
                <span class="menu-arrow">➔</span>
                <a asp-controller="Home" asp-action="AsistenciaGlobal">Calendario</a>
            </li>
            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <li>
                    <span class="menu-arrow">➔</span>
                    <a asp-controller="Admin" asp-action="Index">Panel Admin</a>
                </li>
            }
            <li>
                <span class="menu-arrow">➔</span>
                <a asp-controller="Account" asp-action="Login">Cerrar Sesion</a>
            </li>
        </ul>
    </nav>

    <div class="header-divider"></div>

    @RenderBody()

    <script src="~/js/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>