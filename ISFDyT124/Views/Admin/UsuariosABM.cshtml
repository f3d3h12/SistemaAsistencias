@model IEnumerable<ISFDyT124.DTO.UsuarioDetalleDto>
@{
    ViewData["Title"] = "Gestión de Usuarios";
    ViewData["BodyClass"] = "gestion-page";
}

<div class="admin-banner">
    ADMIN
</div>

<main class="main-container-gestion">
    <div class="toolbar-container">
        <div class="spacer"></div>

        <div class="search-box">
            <input type="text" id="inputBusqueda" placeholder="Buscar usuario...">
            <button class="btn-search" id="btnBuscar">&#128269;</button>
        </div>

        <div class="add-btn-container">
            <a asp-controller="Admin" asp-action="UsuarioAgregar" class="btn-add" id="btnAgregar" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">+</a>
        </div>
    </div>

    <div class="crud-table-container">
        <table class="crud-table">
            <thead>
                <tr>
                    <th style="width: 25%;">Apellido y Nombre</th>
                    <th style="width: 15%;">DNI</th>
                    <th style="width: 15%;">Rol</th>
                    <th style="width: 25%;">Carrera</th>
                    <th style="width: 20%;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UsApellido, @item.UsNombre</td>
                            <td>@item.UsDni</td>
                            <td>@(item.RoDenominacion ?? "Sin Rol")</td>
                            <td>
                                @* Aquí podrías mostrar la carrera si estuviera relacionada directamente *@
                                N/A
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="UsuarioEditar" asp-route-id="@item.UsId" class="btn-edit">✏️</a>
                                    <form asp-action="UsuarioEliminar" asp-route-id="@item.UsId" method="post" style="display:inline;" onsubmit="return confirm('¿Está seguro de eliminar este usuario?');">
                                        <button type="submit" class="btn-delete" style="border:none; background:none; cursor:pointer;">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</main>
