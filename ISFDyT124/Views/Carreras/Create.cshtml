@model ISFDyT124.Models.Carrera

@{
    ViewData["Title"] = "Crear Carrera";
}

<div class="admin-banner">
    CARRERAS
</div>

<main class="main-container-agregar">
    <div class="form-card-agregar">
        <h2 class="form-title"><u>Nueva Carrera</u></h2>

        <form asp-action="Create" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="input-group">
                <label asp-for="CaDenominacion"></label>
                <input asp-for="CaDenominacion" required>
                <span asp-validation-for="CaDenominacion" class="text-danger"></span>
            </div>

            <div class="button-container">
                <button type="submit" class="btn-guardar-estudiante">Guardar</button>
                <a asp-action="Index" class="btn-cancelar">Volver</a>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
